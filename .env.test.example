# Copy to .env.test and fill in your local credentials.
# Tests need a dedicated Postgres database and a spare Redis DB index.
# The global setup pushes the schema and truncates tables, so never
# point these at a database you care about.
PORT=5399
NODE_ENV=development
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/auth_service_test
REDIS_URL=redis://:PASSWORD@localhost:6379/15

JWT_SECRET=integration-test-secret-at-least-32-chars-long
# Generate a throwaway pair:
#   openssl genpkey -algorithm Ed25519 -out jwt-test-private.pem
#   openssl pkey -in jwt-test-private.pem -pubout -out jwt-test-public.pem
JWT_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nCHANGE_ME\n-----END PRIVATE KEY-----\n
JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nCHANGE_ME\n-----END PUBLIC KEY-----\n
JWT_KEY_ID=auth-service-test
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY_DAYS=7

SERVICE_URL=http://localhost:5399
ADMIN_KEY=test-admin-key

# Fake provider creds so the OAuth initiate redirect can be tested
GOOGLE_CLIENT_ID=test-google-client-id
GOOGLE_CLIENT_SECRET=test-google-client-secret
MAIL_PROVIDER=memory
