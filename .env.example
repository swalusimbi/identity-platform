# Server
PORT=5300
NODE_ENV=production

# Database (create with: docker exec postgres psql -U postgres -d main -c "CREATE DATABASE auth_service;")
DATABASE_URL=postgresql://postgres:YOUR_PG_PASSWORD@localhost:5432/auth_service

# Redis (using DB 2 to avoid conflicts with other apps)
REDIS_URL=redis://:YOUR_REDIS_PASSWORD@localhost:6379/3

# JWT fallback secret for legacy HS256 verification and OAuth state encryption
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL

# JWT signing keys for local verification via JWKS (Ed25519 / EdDSA)
# Generate:
#   openssl genpkey -algorithm Ed25519 -out jwt-private.pem
#   openssl pkey -in jwt-private.pem -pubout -out jwt-public.pem
# Store PEMs in env with newlines escaped as \n, or preserve multiline values if your process manager supports them.
JWT_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nCHANGE_ME\n-----END PRIVATE KEY-----
JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nCHANGE_ME\n-----END PUBLIC KEY-----
JWT_KEY_ID=auth-service-v1
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY_DAYS=7

# Service
SERVICE_URL=https://auth.example.com

# Admin key for client registration (generate with: openssl rand -base64 32)
ADMIN_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL

# OAuth (optional — uncomment when ready)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
