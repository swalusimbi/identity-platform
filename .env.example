# Server
PORT=5300
NODE_ENV=production

# Database (create with: docker exec postgres psql -U postgres -d main -c "CREATE DATABASE auth_service;")
DATABASE_URL=postgresql://postgres:YOUR_PG_PASSWORD@localhost:5432/auth_service

# Redis (using DB 2 to avoid conflicts with other apps)
REDIS_URL=redis://:YOUR_REDIS_PASSWORD@localhost:6379/3

# JWT (generate with: openssl rand -base64 48)
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY_DAYS=7

# Service
SERVICE_URL=https://auth.example.com

# Admin key for client registration (generate with: openssl rand -base64 32)
ADMIN_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL

# OAuth (optional — uncomment when ready)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
