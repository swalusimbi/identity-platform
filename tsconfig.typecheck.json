{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "rootDir": "."
  },
  // The SDK declares Express.Request.user as AuthUser for consumers
  // while the platform declares it as TokenPayload, so anything that
  // imports the SDK is checked as its own program (tsconfig.sdk.json):
  // the vendoring tests and the consumer usage fixture. In a real
  // consumer app only one declaration ever exists.
  "include": ["src/**/*", "tests/**/*", "scripts/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "tests/sdk*.test.ts",
    "tests/sdk-consumer-usage.ts"
  ]
}
