{
  "name": "identity-platform",
  "version": "1.0.0",
  "private": true,
  "description": "Identity and access management platform for any application inside an organization",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/swalusimbi/identity-platform.git"
  },
  "bugs": {
    "url": "https://github.com/swalusimbi/identity-platform/issues"
  },
  "homepage": "https://github.com/swalusimbi/identity-platform#readme",
  "engines": {
    "node": ">=24.0.0"
  },
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "typecheck": "tsc -p tsconfig.typecheck.json && tsc -p tsconfig.sdk.json",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:baseline": "tsx scripts/baseline-migrations.ts"
  },
  "dependencies": {
    "argon2": "^0.41.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.45.2",
    "express": "^5.0.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "jose": "^5.9.0",
    "nodemailer": "^9.0.3",
    "postgres": "^3.4.4",
    "swagger-ui-dist": "^5.32.8",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/nodemailer": "^8.0.1",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-dist": "^3.30.6",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.1",
    "supertest": "^7.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.8"
  }
}
