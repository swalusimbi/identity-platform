{
  "name": "auth-service",
  "version": "1.0.0",
  "description": "Standalone authentication microservice — JWT, OAuth2, RBAC, API keys",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "argon2": "^0.41.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.36.0",
    "express": "^5.0.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "jose": "^5.9.0",
    "postgres": "^3.4.4",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/supertest": "^7.2.0",
    "drizzle-kit": "^0.28.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.8"
  }
}
